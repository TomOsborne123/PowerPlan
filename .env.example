PORT=5001

# Scraper / subprocess: show log lines immediately (especially when stdout is a pipe).
PYTHONUNBUFFERED=1

# MySQL (docker-compose)
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=powerplan
DB_NAME=energy_tariff

# If the UI is served on a different origin than this API, allow browser requests:
# CORS_ORIGINS=https://your-frontend.example.com

# Scrape subprocess: Camoufox headless (true), visible browser (false), or Xvfb (virtual).
# Local default is true; the Docker image sets virtual — use the same on Linux if the browser won't start.
# SCRAPER_HEADLESS=virtual
